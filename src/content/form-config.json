{
  "intro": "Fill out the form and we'll get back to you within 24 hours with a quote and available shooting times.",
  "note": "After sending the property details, finish the request by choosing a time in Calendly below.",
  "submitLabel": "Schedule Your Shoot",
  "fields": [
    {
      "name": "fullName",
      "label": "Full Name",
      "type": "text",
      "required": true,
      "placeholder": "John Smith"
    },
    {
      "name": "email",
      "label": "Email",
      "type": "email",
      "required": true,
      "placeholder": "john@example.com"
    },
    {
      "name": "phone",
      "label": "Phone",
      "type": "tel",
      "required": false,
      "placeholder": "(843) 555-0000"
    },
    {
      "name": "propertyAddress",
      "label": "Property Address",
      "type": "text",
      "required": true,
      "placeholder": "123 Main St"
    },
    {
      "name": "unit",
      "label": "Apartment / Unit",
      "type": "text",
      "required": false,
      "placeholder": "Unit, suite, or gate code"
    },
    {
      "name": "city",
      "label": "City",
      "type": "text",
      "required": true,
      "placeholder": "Beaufort"
    },
    {
      "name": "state",
      "label": "State",
      "type": "select",
      "required": true,
      "placeholder": "Select state",
      "defaultValue": "SC",
      "options": [
        "SC",
        "GA",
        "NC"
      ]
    },
    {
      "name": "zipCode",
      "label": "Zip Code",
      "type": "text",
      "required": true,
      "placeholder": "29902"
    },
    {
      "name": "mlsNumber",
      "label": "MLS Number",
      "type": "text",
      "required": false,
      "placeholder": "MLS #"
    },
    {
      "name": "bedrooms",
      "label": "Bedrooms",
      "type": "number",
      "required": false,
      "placeholder": "3"
    },
    {
      "name": "bathrooms",
      "label": "Bathrooms",
      "type": "number",
      "required": false,
      "placeholder": "2"
    },
    {
      "name": "lotSize",
      "label": "Lot Size",
      "type": "text",
      "required": false,
      "placeholder": "0.25 acres"
    },
    {
      "name": "squareFootageRange",
      "label": "Square Footage",
      "type": "select",
      "required": false,
      "placeholder": "Select range",
      "options": [
        "Under 2,000 sq ft",
        "2,001 - 3,500 sq ft",
        "3,501 - 5,000 sq ft",
        "Over 5,000 sq ft"
      ]
    },
    {
      "name": "servicesNeeded",
      "label": "Services Needed",
      "type": "checkbox-group",
      "required": true,
      "options": [
        "Professional Listing Photos",
        "Drone Photography & Video",
        "Video Walkthroughs"
      ]
    },
    {
      "name": "additionalDetails",
      "label": "Additional Details",
      "type": "textarea",
      "required": false,
      "placeholder": "Tell us about the property or any special requests..."
    }
  ]
}
