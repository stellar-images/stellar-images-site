---
interface Credential {
  title: string;
  description: string;
  icon: string;
}

interface Props {
  credential: Credential;
}

const { credential } = Astro.props;
---

<article class="card credential-card stack-sm">
  <div class="icon-badge">{credential.icon}</div>
  <h3>{credential.title}</h3>
  <p>{credential.description}</p>
</article>
