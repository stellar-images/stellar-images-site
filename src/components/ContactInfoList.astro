---
import site from "../content/site.json";
---

<section class="stack-md">
  <div class="stack-xs">
    <p class="eyebrow">Get In Touch</p>
    <h2>Contact details</h2>
    <p>{site.contact.intro}</p>
  </div>

  <div class="contact-info-list">
    <div class="info-row">
      <div class="icon-badge">AREA</div>
      <div>
        <strong>Service Area</strong>
        <p>{site.contact.serviceArea.join(", ")}</p>
      </div>
    </div>

    <div class="info-row">
      <div class="icon-badge">TEL</div>
      <div>
        <strong>Phone</strong>
        <p>{site.contact.phone}</p>
      </div>
    </div>

    <div class="info-row">
      <div class="icon-badge">MAIL</div>
      <div>
        <strong>Email</strong>
        <p>{site.contact.email}</p>
      </div>
    </div>

    <div class="info-row">
      <div class="icon-badge">HRS</div>
      <div>
        <strong>Hours</strong>
        <p>{site.contact.hours}</p>
      </div>
    </div>
  </div>
</section>
