---
import site from "../content/site.json";
import IconBadge from "./IconBadge.astro";
---

<section class="stack-md">
  <div class="stack-xs">
    <p class="eyebrow">Get In Touch</p>
    <h2>Contact details</h2>
    <p>{site.contact.intro}</p>
  </div>

  <div class="contact-info-list">
    <div class="info-row">
      <IconBadge icon="area" />
      <div>
        <strong>Service Area</strong>
        <p>{site.contact.serviceArea.join(", ")}</p>
      </div>
    </div>

    <div class="info-row">
      <IconBadge icon="tel" />
      <div>
        <strong>Phone</strong>
        <p>{site.contact.phone}</p>
      </div>
    </div>

    <div class="info-row">
      <IconBadge icon="mail" />
      <div>
        <strong>Email</strong>
        <p>{site.contact.email}</p>
      </div>
    </div>

    <div class="info-row">
      <IconBadge icon="hrs" />
      <div>
        <strong>Hours</strong>
        <p>{site.contact.hours}</p>
      </div>
    </div>
  </div>
</section>
