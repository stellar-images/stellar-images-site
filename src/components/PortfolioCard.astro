---
import type { PortfolioItem } from "../lib/portfolio";

interface Props {
  item: PortfolioItem;
}

const { item } = Astro.props;
---

<article class="portfolio-card" id={item.id} data-category={item.category.toLowerCase()}>
  <a class="portfolio-card-link" href={`/portfolio/${item.id}/`} aria-label={`View ${item.title} portfolio project`}>
    <img src={item.image} alt={item.alt} />
    <div class="portfolio-card-body stack-xs">
      <div class="portfolio-card-meta">
        <p class="eyebrow">{item.category}</p>
        <span>{item.location}</span>
      </div>
      <h3>{item.title}</h3>
      <p>{item.summary}</p>
      <span class="portfolio-card-action">View project</span>
    </div>
  </a>
</article>
