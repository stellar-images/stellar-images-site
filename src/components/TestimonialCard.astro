---
interface Testimonial {
  quote: string;
  name: string;
  role: string;
  stars: number;
}

interface Props {
  testimonial: Testimonial;
}

const { testimonial } = Astro.props;
const ratingLabel = `${testimonial.stars} out of 5 stars`;
const stars = "★".repeat(testimonial.stars);
---

<article class="card testimonial-card stack-sm">
  <p class="stars" aria-label={ratingLabel}>{stars}</p>
  <p>“{testimonial.quote}”</p>
  <div>
    <strong>{testimonial.name}</strong>
    <p>{testimonial.role}</p>
  </div>
</article>
