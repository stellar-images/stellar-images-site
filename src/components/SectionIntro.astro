---
interface Props {
  eyebrow: string;
  title: string;
  description?: string;
  align?: "left" | "center";
}

const { eyebrow, title, description, align = "center" } = Astro.props;
---

<div class:list={["section-intro", `align-${align}`]}>
  <p class="eyebrow">{eyebrow}</p>
  <h2>{title}</h2>
  {description && <p>{description}</p>}
</div>
