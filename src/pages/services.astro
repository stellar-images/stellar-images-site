---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import SectionIntro from "../components/SectionIntro.astro";
import ServiceCard from "../components/ServiceCard.astro";
import CallToAction from "../components/CallToAction.astro";
import site from "../content/site.json";
import services from "../content/services.json";
import pages from "../content/pages.json";
---

<BaseLayout title={`Services | ${site.businessName}`} description="Service lineup, features, and starting pricing.">
  <Header currentPath="/services" />
  <main id="main-content">
    <section class="page-hero">
      <div class="container stack-md">
        <p class="eyebrow">{pages.services.hero.eyebrow}</p>
        <h1>{pages.services.hero.heading}</h1>
        <p class="hero-copy">{pages.services.hero.description}</p>
      </div>
    </section>

    <section class="section">
      <div class="container stack-lg">
        <SectionIntro
          eyebrow={pages.services.overview.eyebrow}
          title={pages.services.overview.title}
          description={pages.services.overview.description}
        />
        <div class="grid cards-3">
          {services.services.map((service) => <ServiceCard service={service} />)}
        </div>
      </div>
    </section>

    <section class="section section-alt">
      <div class="container stack-xl">
        {services.services.map((service) => (
          <article class="service-detail card stack-lg" id={service.slug}>
            <div class="service-detail-head">
              <div class="stack-sm">
                <p class="eyebrow">{service.shortLabel}</p>
                <h2>{service.name}</h2>
                <p>{service.longDescription}</p>
              </div>
              <div class="price-chip">Starting at {service.startingPrice}</div>
            </div>

            <div class="two-column">
              <div class="stack-md">
                <h3>What’s included</h3>
                <ul class="feature-list">
                  {service.features.map((feature) => <li>{feature}</li>)}
                </ul>
              </div>

              <div class="stack-md">
                <h3>Pricing</h3>
                <div class="pricing-table">
                  {service.pricingRows.map((row) => (
                    <div class="pricing-row">
                      <span>{row.label}</span>
                      <strong>{row.price}</strong>
                    </div>
                  ))}
                </div>
              </div>
            </div>
          </article>
        ))}
      </div>
    </section>

    <CallToAction
      eyebrow={pages.services.cta.eyebrow}
      title={pages.services.cta.title}
      description={pages.services.cta.description}
      primaryHref="/contact"
      primaryLabel={pages.services.cta.primaryLabel}
      secondaryHref="/portfolio"
      secondaryLabel={pages.services.cta.secondaryLabel}
    />
  </main>
  <Footer />
</BaseLayout>
