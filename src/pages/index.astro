---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import HeroSection from "../components/HeroSection.astro";
import SectionIntro from "../components/SectionIntro.astro";
import ServiceCard from "../components/ServiceCard.astro";
import PortfolioCard from "../components/PortfolioCard.astro";
import TestimonialCard from "../components/TestimonialCard.astro";
import CredentialCard from "../components/CredentialCard.astro";
import CallToAction from "../components/CallToAction.astro";
import site from "../content/site.json";
import services from "../content/services.json";
import portfolio from "../content/portfolio.json";
import testimonials from "../content/testimonials.json";
import credentials from "../content/credentials.json";
import pages from "../content/pages.json";

const featuredWork = portfolio.portfolio.filter((item) => item.featured).slice(0, 4);
const featuredTestimonials = testimonials.testimonials.slice(0, 3);
const featuredCredentials = credentials.credentials.slice(0, 4);
---

<BaseLayout title={site.seo.defaultTitle} description={site.seo.defaultDescription}>
  <Header currentPath="/" />
  <main id="main-content">
    <HeroSection />

    <section class="section">
      <div class="container stack-lg">
        <SectionIntro
          eyebrow={pages.home.aboutSection.eyebrow}
          title={site.aboutPreview.heading}
          description={site.aboutPreview.paragraphs[0]}
          align="left"
        />
        <div class="two-column narrative">
          <div class="stack-md prose">
            {site.aboutPreview.paragraphs.slice(1).map((paragraph) => <p>{paragraph}</p>)}
          </div>
          <aside class="card portrait-card">
            <img src={site.aboutImage.src} alt={site.aboutImage.alt} />
            <div class="stack-xs">
              <h3>{site.aboutImage.captionTitle}</h3>
              <p>{site.aboutImage.captionText}</p>
            </div>
          </aside>
        </div>
      </div>
    </section>

    <section class="section section-alt">
      <div class="container stack-lg">
        <SectionIntro
          eyebrow={pages.home.servicesSection.eyebrow}
          title={pages.home.servicesSection.title}
          description={pages.home.servicesSection.description}
        />
        <div class="grid cards-3">
          {services.services.slice(0, 3).map((service) => <ServiceCard service={service} />)}
        </div>
      </div>
    </section>

    <section class="section">
      <div class="container stack-lg">
        <div class="section-heading-row">
          <SectionIntro
            eyebrow={pages.home.portfolioSection.eyebrow}
            title={pages.home.portfolioSection.title}
            description={pages.home.portfolioSection.description}
            align="left"
          />
          <a class="inline-link" href="/portfolio">{pages.home.portfolioSection.linkLabel}</a>
        </div>
        <div class="grid cards-2">
          {featuredWork.map((item) => <PortfolioCard item={item} />)}
        </div>
      </div>
    </section>

    <section class="section section-alt">
      <div class="container stack-lg">
        <SectionIntro
          eyebrow={pages.home.testimonialsSection.eyebrow}
          title={pages.home.testimonialsSection.title}
          description={pages.home.testimonialsSection.description}
        />
        <div class="grid cards-3">
          {featuredTestimonials.map((testimonial) => <TestimonialCard testimonial={testimonial} />)}
        </div>
      </div>
    </section>

    <section class="section">
      <div class="container stack-lg">
        <SectionIntro
          eyebrow={pages.home.credentialsSection.eyebrow}
          title={pages.home.credentialsSection.title}
          description={pages.home.credentialsSection.description}
        />
        <div class="grid cards-4">
          {featuredCredentials.map((credential) => <CredentialCard credential={credential} />)}
        </div>
      </div>
    </section>

    <CallToAction
      eyebrow={pages.home.cta.eyebrow}
      title={pages.home.cta.title}
      description={pages.home.cta.description}
      primaryHref="/contact"
      primaryLabel={pages.home.cta.primaryLabel}
      secondaryHref="/services"
      secondaryLabel={pages.home.cta.secondaryLabel}
    />
  </main>
  <Footer />
</BaseLayout>
