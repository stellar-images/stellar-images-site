---
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex" />
    <title>Content Manager</title>
    <style>
      :root {
        color-scheme: light;
        --admin-note-bg: #f6f1e7;
        --admin-note-border: #d9c5a1;
        --admin-note-ink: #241f17;
        --admin-note-muted: #6f6250;
        --admin-note-accent: #8d5c2f;
      }

      body {
        margin: 0;
      }

      .admin-help {
        background:
          linear-gradient(135deg, rgba(255, 255, 255, 0.86), rgba(246, 241, 231, 0.96)),
          var(--admin-note-bg);
        border: 1px solid var(--admin-note-border);
        border-radius: 18px;
        bottom: 16px;
        box-shadow: 0 18px 50px rgba(25, 21, 15, 0.18);
        color: var(--admin-note-ink);
        font-family: ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        left: 16px;
        max-height: min(76vh, 640px);
        max-width: 920px;
        overflow: auto;
        padding: 0;
        position: fixed;
        width: min(calc(100vw - 32px), 920px);
        z-index: 2147483646;
      }

      .admin-help:not([open]) {
        width: auto;
      }

      .admin-help__summary {
        align-items: center;
        cursor: pointer;
        display: flex;
        gap: 12px;
        list-style: none;
        padding: 12px 16px;
      }

      .admin-help__summary::-webkit-details-marker {
        display: none;
      }

      .admin-help__summary::after {
        border: solid var(--admin-note-accent);
        border-width: 0 2px 2px 0;
        content: "";
        height: 8px;
        margin-left: auto;
        transform: rotate(45deg);
        transform-origin: center;
        transition: transform 160ms ease;
        width: 8px;
      }

      .admin-help[open] .admin-help__summary::after {
        transform: rotate(-135deg);
      }

      .admin-help[open] .admin-help__summary {
        border-bottom: 1px solid rgba(217, 197, 161, 0.82);
      }

      .admin-help__eyebrow {
        color: var(--admin-note-accent);
        font-size: 11px;
        font-weight: 800;
        letter-spacing: 0.12em;
        text-transform: uppercase;
      }

      .admin-help__title {
        font-size: clamp(16px, 2vw, 20px);
        font-weight: 800;
        line-height: 1.2;
      }

      .admin-help__body {
        display: grid;
        gap: 18px;
        grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
        padding: 16px;
      }

      .admin-help__section {
        background: rgba(255, 255, 255, 0.58);
        border: 1px solid rgba(217, 197, 161, 0.82);
        border-radius: 14px;
        padding: 14px 16px;
      }

      .admin-help h2 {
        font-size: 13px;
        letter-spacing: 0.04em;
        margin: 0 0 8px;
        text-transform: uppercase;
      }

      .admin-help ol,
      .admin-help ul {
        margin: 0;
        padding-left: 20px;
      }

      .admin-help li {
        color: var(--admin-note-muted);
        font-size: 13px;
        line-height: 1.45;
        margin: 5px 0;
      }

      .admin-help strong {
        color: var(--admin-note-ink);
      }

      @media (max-width: 760px) {
        .admin-help {
          bottom: 10px;
          left: 10px;
          max-height: 70vh;
          width: min(calc(100vw - 20px), 920px);
        }

        .admin-help__body {
          grid-template-columns: 1fr;
        }

        .admin-help__summary {
          align-items: flex-start;
        }
      }
    </style>
  </head>
  <body>
    <details class="admin-help">
      <summary class="admin-help__summary">
        <span class="admin-help__eyebrow">Admin notes</span>
        <span class="admin-help__title">How edits become website updates</span>
      </summary>

      <div class="admin-help__body">
        <section class="admin-help__section" aria-labelledby="admin-publishing-flow-title">
          <h2 id="admin-publishing-flow-title">Publishing Flow</h2>
          <ol>
            <li>Edit the content fields in this admin panel.</li>
            <li>Click <strong>Publish</strong> so the CMS saves the change to GitHub.</li>
            <li>Vercel sees the GitHub update, rebuilds the site, and publishes the new version.</li>
            <li>Wait a few minutes, then refresh the public website to confirm the change.</li>
          </ol>
        </section>

        <section class="admin-help__section" aria-labelledby="admin-update-quirks-title">
          <h2 id="admin-update-quirks-title">Important Quirks</h2>
          <ul>
            <li>This is a structured form editor, not a drag-and-drop page builder or instant live preview.</li>
            <li>The admin form follows a fixed site schema. If a field is missing here, the schema has to be updated before that content can be edited.</li>
            <li>Portfolio entries become public cards and detail pages when <strong>Published</strong> is enabled.</li>
            <li>Use <strong>Sort Order</strong> values like 10, 20, and 30 so new portfolio projects can be inserted later without renumbering everything.</li>
            <li>Fields marked <strong>Advanced</strong> control form behavior and email payloads. Change them only intentionally.</li>
            <li>Uploaded images and text become public website content. Do not add passwords, private client notes, or account secrets.</li>
            <li>Use web-ready portfolio images, not full-resolution client delivery folders.</li>
            <li>If login gets stuck or the editor looks empty, use <strong>Reset CMS Login</strong> and try again.</li>
          </ul>
        </section>
      </div>
    </details>

    <script is:inline>
      (() => {
        const authStorageKeys = [
          "decap-cms-user",
          "netlify-cms-user",
          "cms-user",
        ];
        const resetParam = "reset-login";
        const nativeOpen = window.open.bind(window);

        function clearAdminAuthState() {
          for (const storage of [window.localStorage, window.sessionStorage]) {
            for (let index = storage.length - 1; index >= 0; index -= 1) {
              const key = storage.key(index);
              if (!key) continue;

              const normalizedKey = key.toLowerCase();
              if (
                authStorageKeys.includes(key) ||
                normalizedKey.includes("decap") ||
                normalizedKey.includes("netlify-cms")
              ) {
                storage.removeItem(key);
              }
            }
          }
        }

        function resetAdminLogin() {
          clearAdminAuthState();
          window.location.replace("/admin/#/");
        }

        function addResetButton() {
          if (document.querySelector("[data-admin-reset-login]")) return;

          const button = document.createElement("button");
          button.type = "button";
          button.textContent = "Reset CMS Login";
          button.setAttribute("data-admin-reset-login", "");
          button.setAttribute("aria-label", "Reset CMS login and reload the admin page");
          button.style.cssText = [
            "position:fixed",
            "right:16px",
            "bottom:16px",
            "z-index:2147483647",
            "border:0",
            "border-radius:999px",
            "background:#1f2937",
            "color:#fff",
            "font:600 13px/1 system-ui,sans-serif",
            "padding:10px 14px",
            "box-shadow:0 8px 24px rgba(0,0,0,.18)",
            "cursor:pointer",
          ].join(";");
          button.addEventListener("click", resetAdminLogin);
          document.body.append(button);
        }

        if (new URLSearchParams(window.location.search).has(resetParam)) {
          resetAdminLogin();
          return;
        }

        window.addEventListener("load", addResetButton);

        window.open = (url, target, features) => {
          const popup = nativeOpen(url, target, features);

          if (popup) {
            return popup;
          }

          if (typeof url === "string" && url.includes("/api/auth")) {
            window.location.assign(url);

            return {
              close() {},
              focus() {},
            };
          }

          return popup;
        };
      })();
    </script>

    <script is:inline>
      (() => {
        const entryRoutePattern = /^#\/collections\/[^/]+\/entries\/[^/]+/;
        const reloadKeyPrefix = "stellar-admin-entry-health:";
        let healthCheckTimer;

        function clearEntryReloadKeys() {
          for (let index = sessionStorage.length - 1; index >= 0; index -= 1) {
            const key = sessionStorage.key(index);
            if (key?.startsWith(reloadKeyPrefix)) {
              sessionStorage.removeItem(key);
            }
          }
        }

        function visibleValueFields() {
          return Array.from(
            document.querySelectorAll("input, textarea, select"),
          ).filter((field) => {
            if (!(field instanceof HTMLInputElement || field instanceof HTMLTextAreaElement || field instanceof HTMLSelectElement)) {
              return false;
            }

            if (field instanceof HTMLInputElement && ["button", "file", "hidden", "submit"].includes(field.type)) {
              return false;
            }

            return field.offsetParent !== null;
          });
        }

        function normalizedText(value) {
          return String(value ?? "").replace(/\s+/g, " ").trim().toLowerCase();
        }

        function labelCandidates(field) {
          const candidates = [
            field.getAttribute("aria-label"),
            field.getAttribute("placeholder"),
          ];
          const labelledBy = field.getAttribute("aria-labelledby");

          if (labelledBy) {
            labelledBy.split(/\s+/).forEach((id) => {
              const label = document.getElementById(id);
              if (label?.innerText) candidates.push(label.innerText);
            });
          }

          if ("labels" in field && field.labels) {
            Array.from(field.labels).forEach((label) => candidates.push(label.innerText));
          }

          return candidates.map(normalizedText).filter(Boolean);
        }

        function fieldHasValue(field) {
          if (field instanceof HTMLInputElement && ["checkbox", "radio"].includes(field.type)) {
            return field.checked;
          }

          if (typeof field.value !== "string") return false;

          const value = normalizedText(field.value);
          if (!value) return false;

          return !labelCandidates(field).includes(value);
        }

        function entryLooksUnhydrated() {
          const bodyText = document.body.innerText.trim();

          if (!bodyText) return true;
          if (/Loading (configuration|entry)/i.test(bodyText)) return true;
          if (!bodyText.includes("Writing in")) return false;

          const fields = visibleValueFields();
          if (fields.length === 0) return false;

          return !fields.some(fieldHasValue);
        }

        function scheduleEntryHealthCheck() {
          window.clearTimeout(healthCheckTimer);

          const hash = window.location.hash;

          if (!entryRoutePattern.test(hash)) {
            clearEntryReloadKeys();
            return;
          }

          healthCheckTimer = window.setTimeout(() => {
            if (!entryRoutePattern.test(window.location.hash)) return;
            if (!entryLooksUnhydrated()) return;

            const reloadKey = `${reloadKeyPrefix}${window.location.hash}`;
            const reloadCount = Number(sessionStorage.getItem(reloadKey) ?? "0");

            if (reloadCount >= 2) return;

            sessionStorage.setItem(reloadKey, String(reloadCount + 1));
            window.location.reload();
          }, 3000);
        }

        scheduleEntryHealthCheck();
        window.addEventListener("load", scheduleEntryHealthCheck);
        window.addEventListener("hashchange", scheduleEntryHealthCheck);
      })();
    </script>
    <script is:inline src="https://unpkg.com/decap-cms@3.12.2/dist/decap-cms.js"></script>
  </body>
</html>
