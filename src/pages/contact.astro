---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import BookingForm from "../components/BookingForm.astro";
import ContactInfoList from "../components/ContactInfoList.astro";
import CalendlyEmbed from "../components/CalendlyEmbed.astro";
import site from "../content/site.json";
import formConfig from "../content/form-config.json";
import pages from "../content/pages.json";
---

<BaseLayout title={`Contact & Book | ${site.businessName}`} description="Property intake and scheduling in one place.">
  <Header currentPath="/contact" />
  <main id="main-content">
    <section class="page-hero page-hero-image page-hero-contact">
      <div class="container stack-md">
        {pages.contact.hero.eyebrow && <p class="eyebrow">{pages.contact.hero.eyebrow}</p>}
        <h1>{pages.contact.hero.heading}</h1>
        <p class="hero-copy">{pages.contact.hero.description}</p>
      </div>
    </section>

    <section class="section">
      <div class="container booking-layout">
        <aside class="stack-lg">
          <ContactInfoList />
        </aside>

        <div class="stack-lg">
          <BookingForm config={formConfig} />
          <CalendlyEmbed />
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
