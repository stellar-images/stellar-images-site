---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import SectionIntro from "../components/SectionIntro.astro";
import CredentialCard from "../components/CredentialCard.astro";
import CallToAction from "../components/CallToAction.astro";
import site from "../content/site.json";
import credentials from "../content/credentials.json";
import pages from "../content/pages.json";
---

<BaseLayout title={`About | ${site.businessName}`} description="Founder story, credentials, and service approach.">
  <Header currentPath="/about" />
  <main id="main-content">
    <section class="page-hero">
      <div class="container stack-md">
        <p class="eyebrow">{pages.about.hero.eyebrow}</p>
        <h1>{pages.about.hero.heading}</h1>
        <p class="hero-copy">{pages.about.hero.description}</p>
      </div>
    </section>

    <section class="section">
      <div class="container two-column about-grid">
        <div class="stack-lg">
          <SectionIntro
            eyebrow="About Stellar Images"
            title={site.aboutPreview.heading}
            description={site.aboutPreview.paragraphs[0]}
            align="left"
          />
          <div class="stack-md prose">
            {site.aboutPreview.paragraphs.map((paragraph) => <p>{paragraph}</p>)}
          </div>
        </div>

        <aside class="card portrait-card">
          <img src={site.aboutImage.src} alt={site.aboutImage.alt} />
          <div class="stack-xs">
            <h3>{site.aboutImage.captionTitle}</h3>
            <p>{site.aboutImage.captionText}</p>
          </div>
        </aside>
      </div>
    </section>

    <section class="section section-alt">
      <div class="container stack-lg">
        <SectionIntro
          eyebrow={pages.about.credentialsSection.eyebrow}
          title={pages.about.credentialsSection.title}
          description={pages.about.credentialsSection.description}
        />
        <div class="grid cards-4">
          {credentials.credentials.map((credential) => <CredentialCard credential={credential} />)}
        </div>
      </div>
    </section>

    <CallToAction
      eyebrow={pages.about.cta.eyebrow}
      title={pages.about.cta.title}
      description={pages.about.cta.description}
      primaryHref="/contact"
      primaryLabel={pages.about.cta.primaryLabel}
      secondaryHref="/services"
      secondaryLabel={pages.about.cta.secondaryLabel}
    />
  </main>
  <Footer />
</BaseLayout>
