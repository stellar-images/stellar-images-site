# Email intake delivery. These are read only by the Vercel /api/intake function.
RESEND_API_KEY=
INTAKE_TO_EMAIL=
INTAKE_FROM_EMAIL=

# Decap CMS GitHub OAuth. These are read only by the Vercel /api/auth and /api/callback functions.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
OAUTH_STATE_SECRET=
OAUTH_REDIRECT_URI=
GITHUB_OAUTH_SCOPE=repo
